{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "custom": {
      "contentSize": "1200px",
      "wideSize": "1320px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "white", "name": "White", "color": "#ffffff" },
        { "slug": "primary", "name": "Institutional Blue", "color": "#3969b1" },
        { "slug": "offwhite", "name": "Off White", "color": "#f4f6f8" },
        { "slug": "text", "name": "Text", "color": "#1a2433" },
        { "slug": "muted", "name": "Muted", "color": "#6b7280" },
        { "slug": "success", "name": "Accent Green", "color": "#1f8f63" }
      ]
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1320px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw", "vh"],
      "spacingSizes": [
        { "slug": "20", "size": "0.5rem", "name": "2XS" },
        { "slug": "30", "size": "0.75rem", "name": "XS" },
        { "slug": "40", "size": "1rem", "name": "S" },
        { "slug": "50", "size": "1.5rem", "name": "M" },
        { "slug": "60", "size": "2rem", "name": "L" },
        { "slug": "70", "size": "3rem", "name": "XL" },
        { "slug": "80", "size": "4rem", "name": "2XL" }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
          "name": "System UI",
          "slug": "system-ui"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.9rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "2rem", "name": "XL" },
        { "slug": "xx-large", "size": "2.8rem", "name": "2XL" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-ui)",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontWeight": "600",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "var(--wp--preset--color--text)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "button": {
        "border": {
          "radius": "0.5rem"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "spacing": {
          "padding": {
            "top": "0.8rem",
            "right": "1.25rem",
            "bottom": "0.8rem",
            "left": "1.25rem"
          }
        },
        "typography": {
          "fontWeight": "600"
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
